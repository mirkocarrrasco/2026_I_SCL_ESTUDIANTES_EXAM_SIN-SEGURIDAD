package com.mitocode.orchestrator.client.inventories.restclient;

import com.mitocode.orchestrator.client.inventories.dto.OrderItemRequest;
import com.mitocode.orchestrator.client.inventories.dto.ReleaseOrderRequest;
import com.mitocode.orchestrator.client.inventories.dto.ReserveOrderRequest;
import com.mitocode.orchestrator.client.inventories.dto.ReserveOrderResponse;
import com.mitocode.orchestrator.controller.dto.CreateOrderOrchestratorRequest;
import lombok.AllArgsConstructor;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Component;
import org.springframework.web.client.RestClient;

import java.util.UUID;

@Component
@AllArgsConstructor
public class ShipmentServiceV1RestClient {

    private final RestClient shipmentV1RestClient;

    public ReserveOrderResponse reserverOrder(UUID orderId, CreateOrderOrchestratorRequest orchestratorRequest) {

        ReserveOrderRequest request = new ReserveOrderRequest(
                orderId,
                orchestratorRequest.warehouse().id(),
                orchestratorRequest.customer().id(),
                orchestratorRequest.items()
                        .stream()
                        .map(item -> new OrderItemRequest(
                                item.product().id(),
                                item.product().name(),
                                item.quantity(),
                                item.description()
                        ))
                        .toList()
        );

        return shipmentV1RestClient.post()
                .uri("/{warehouseId}/orders/reserve", orchestratorRequest.warehouse().id())
                //.header("Content-Type", "application/json")
                .body(request)
                .retrieve()
                .body(ReserveOrderResponse.class);
    }

    public ResponseEntity<Void> releaseOrder(UUID orderId, Long warehouseId) {
        ReleaseOrderRequest releaseOrderRequest = new ReleaseOrderRequest(orderId);

        return shipmentV1RestClient.post()
                .uri("/{warehouseId}/orders/release", warehouseId)
                .body(releaseOrderRequest)
                .retrieve()
                .toBodilessEntity();
    }
}
