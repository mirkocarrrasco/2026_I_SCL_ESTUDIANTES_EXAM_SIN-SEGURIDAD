package com.mitocode.shipment.producer.driver.released;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.mitocode.shipment.domain.Shipment;
import com.mitocode.shipment.producer.driver.released.event.CourierReleasedEvent;
import lombok.AllArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.kafka.core.KafkaTemplate;
import org.springframework.stereotype.Component;

@Slf4j
@Component
@AllArgsConstructor
public class CourierReleasedProducer {

    private static final String TOPIC = "shipment.driver-released.v1";
    private final KafkaTemplate<String, Object> kafkaTemplate;
    private final ObjectMapper mapper;

    public void produce(Shipment shipment) {

        try {
            CourierReleasedEvent event = new CourierReleasedEvent();
            event.setOrderId(shipment.getOrderId().toString());
            event.setStatus(shipment.getStatus().name());

            kafkaTemplate.send(TOPIC, shipment.getOrderId().toString(), mapper.writeValueAsString(event));

            log.info("Driver Released Event sent");
        } catch (Exception ex) {
            log.error("Error trying to send Driver Released Event", ex);
        }

    }
}
